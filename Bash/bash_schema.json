{
  "name": "restricted_shell",
  "description": "Run a single safe command in the agent sandbox",
  "parameters": {
    "type": "object",
    "properties": {
      "cmd": { "type": "string", "enum": ["ls", "pwd", "cat", "head", "tail", "grep", "wc", "sed", "awk", "mkdir", "touch"] },
      "args": { "type": "array", "items": { "type": "string" }, "default": [] }
    },
    "required": ["cmd"]
  }
}
